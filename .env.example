# Analytics Configuration
# Privacy-respecting analytics using Plausible Analytics
# Set VITE_ANALYTICS_ENABLED=true to enable analytics

# Enable/disable analytics (default: false)
VITE_ANALYTICS_ENABLED=false

# Your Plausible domain (the domain you registered with Plausible)
VITE_ANALYTICS_DOMAIN=calculator-pensie.example.com

# Plausible script source (default: official Plausible CDN)
# For self-hosted Plausible, use your own domain
VITE_ANALYTICS_SCRIPT_SRC=https://plausible.io/js/script.js

# Plausible API host (default: https://plausible.io)
# For self-hosted Plausible, use your own domain
VITE_ANALYTICS_API_HOST=https://plausible.io

# Track events on localhost (default: false)
# Set to true for development/testing
VITE_ANALYTICS_TRACK_LOCALHOST=false

# Enable hash-based routing tracking (default: false)
# Set to true if your app uses hash routing (e.g., /#/page)
VITE_ANALYTICS_HASH_MODE=false
