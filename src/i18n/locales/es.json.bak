  "help": {
    "title": "Centro de Ayuda",
    "close": "Cerrar",
    "startTour": "Iniciar Recorrido",
    "openHelp": "Ayuda",
    "skipTour": "Omitir",
    "nextStep": "Siguiente",
    "prevStep": "Anterior",
