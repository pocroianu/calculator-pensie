    "stepOf": "Paso {{current}} de {{total}}",
    "tour": {
      "welcome": {
        "title": "¡Bienvenido al Calculador de Pensiones!",
        "description": "Este recorrido guiado le ayudará a entender cómo usar el calculador para estimar su pensión rumana. ¡Comencemos!"
      },
      "birthDate": {
        "title": "Fecha de Nacimiento",
        "description": "Ingrese su fecha de nacimiento aquí. Se utiliza para calcular su edad actual y determinar cuándo será elegible para la jubilación (la edad estándar de jubilación es 65 años)."
      },
      "retirementYear": {
        "title": "Año Planificado de Jubilación",
        "description": "Ingrese el año en que planea jubilarse. El calculador sugerirá un año basado en la edad estándar de jubilación de 65 años, pero puede ajustarlo."
      },
      "contributionPeriods": {
        "title": "Períodos de Contribución",
        "description": "Agregue sus períodos de empleo aquí. Cada período contribuye a sus puntos de pensión según el salario y la duración. También puede agregar períodos no contributivos como servicio militar o universidad."
      },
      "workingConditions": {
        "title": "Condiciones de Trabajo",
        "description": "Si trabajó en condiciones difíciles o especiales, puede tener derecho a puntos de bonificación: Grupa II (Difíciles) otorga 25% de bonificación, Grupa I (Muy Difíciles) y Condiciones Especiales otorgan 50% de bonificación."
      },
      "pensionEstimate": {
        "title": "Su Estimación de Pensión",
        "description": "Esto muestra su pensión mensual y anual estimada basada en sus puntos totales. El cálculo utiliza el valor de referencia de 2024 de 81.03 RON por punto."
      },
      "complete": {
        "title": "¡Recorrido Completo!",
        "description": "¡Ahora conoce los conceptos básicos! No dude en explorar la sección de Preguntas Frecuentes para obtener información más detallada sobre cómo funcionan los cálculos de pensión."
      }
    },
    "faq": {
      "title": "Preguntas Frecuentes",
      "questions": {
        "howCalculated": {
          "question": "¿Cómo se calcula la pensión?",
          "answer": "Su pensión se calcula con la fórmula: Pensión Mensual = Puntos Totales x Valor de Referencia (81.03 RON). Los Puntos Totales incluyen puntos de contribución (basados en la relación entre su salario y el salario promedio), puntos de estabilidad (basados en los años trabajados) y puntos no contributivos."
        },
        "contributionPoints": {
          "question": "¿Qué son los puntos de contribución?",
          "answer": "Los puntos de contribución se calculan en base a la relación entre su salario bruto y el salario promedio nacional por cada año trabajado. Si su salario es igual al promedio, gana 1 punto por año. Salarios más altos generan proporcionalmente más puntos."
        },
        "stabilityPoints": {
          "question": "¿Qué son los puntos de estabilidad?",
          "answer": "Los puntos de estabilidad recompensan el empleo a largo plazo. Gana 0.5 puntos por cada año trabajado más allá del período mínimo de contribución de 15 años, hasta el período completo de contribución de 35 años."
        },
        "nonContributive": {
          "question": "¿Qué son los períodos no contributivos?",
          "answer": "Los períodos no contributivos son intervalos de tiempo que cuentan para su pensión incluso sin aportes salariales. Estos incluyen: Servicio Militar (0.25 puntos/año), Estudios Universitarios (0.25 puntos/año), Cuidado de Hijos (0.25 puntos/año) y Licencia Médica (0.20 puntos/año)."
        },
        "workingConditions": {
          "question": "¿Cómo afectan las condiciones de trabajo a mi pensión?",
          "answer": "Si trabajó en condiciones especiales, recibe puntos de bonificación: Condiciones Normales - sin bonificación, Grupa II (Condiciones difíciles) - 25% de bonificación en puntos de contribución, Grupa I (Condiciones muy difíciles) - 50% de bonificación, Condiciones Especiales - 50% de bonificación."
        },
        "minimumContribution": {
          "question": "¿Cuál es el período mínimo de contribución?",
          "answer": "El período mínimo de contribución en Rumanía es de 15 años. Necesita al menos esta cantidad de años de aportes para ser elegible para una pensión. El período completo de contribución es de 35 años."
        },
        "retirementAge": {
          "question": "¿Cuál es la edad estándar de jubilación?",
          "answer": "La edad estándar de jubilación en Rumanía es de 65 años. Es cuando se vuelve elegible para recibir los beneficios completos de pensión, asumiendo que ha cumplido con los requisitos mínimos de contribución."
        },
        "referenceValue": {
          "question": "¿Qué es el valor de referencia del punto de pensión?",
          "answer": "El valor de referencia (valoarea punctului de pensie) es la cantidad en RON que vale cada punto de pensión. A partir de 2024, este valor es de 81.03 RON. Este valor es ajustado periódicamente por el gobierno."
        }
      }
    },
    "tooltips": {
      "birthDate": "Su fecha de nacimiento se utiliza para calcular su edad actual y determinar la elegibilidad para la jubilación. La edad estándar de jubilación es 65 años.",
      "retirementYear": "El año en que planea jubilarse. Puede jubilarse después de cumplir 65 años, asumiendo que se cumplen los requisitos mínimos de contribución.",
      "monthlyGrossSalary": "Su salario bruto mensual antes de impuestos. Se compara con el promedio nacional para calcular los puntos de contribución.",
      "startDate": "La fecha de inicio de este período de empleo o no contributivo.",
      "endDate": "La fecha de finalización de este período de empleo o no contributivo.",
      "company": "Opcional: El nombre de la empresa u organización donde trabajó.",
      "workingCondition": "Seleccione las condiciones de trabajo para este período. Las condiciones especiales otorgan puntos de bonificación: Grupa II +25%, Grupa I +50%, Especiales +50%.",
      "nonContributiveType": "El tipo de período no contributivo. Diferentes tipos generan diferentes tasas de puntos por año.",
      "contributionPoints": "Puntos ganados en base a su salario comparado con el promedio nacional. Mayor salario = más puntos.",
      "stabilityPoints": "Puntos de bonificación por empleo a largo plazo. Se ganan por años más allá del mínimo de 15 años, hasta 35 años.",
      "totalPoints": "La suma de todos sus puntos: contribución + estabilidad + no contributivos. Multiplicados por 81.03 RON para obtener su pensión."
    }
  },
